# =============================
# 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env ファイルは .gitignore により Git 管理対象外です。
# =============================

# ステージング環境のベースURL
BASE_URL=https://staging.example.com

# テスト用一般ユーザー
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=

# テスト用管理者ユーザー
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=
